#!/usr/bin/env bash
# usagewidget — client and deployment helper for the UsageWidget companion API.
set -euo pipefail

CONFIG_DIR="${USAGEWIDGET_CONFIG_DIR:-$HOME/.config/usagewidget}"
CONFIG_FILE="${USAGEWIDGET_CONFIG:-$CONFIG_DIR/env}"
SERVER_ENV="${USAGEWIDGET_SERVER_ENV:-/etc/usagewidget/env}"
DEFAULT_URL=""
DEFAULT_LOCAL_URL="http://127.0.0.1:8377"
DEFAULT_HOST=""
DEFAULT_REPO=""

die() { echo "usagewidget: $*" >&2; exit 1; }

load_config() {
  local default_url="$DEFAULT_URL"
  if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    set -a
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
    set +a
  elif [[ -r "$SERVER_ENV" ]]; then
    # On the server, talk directly to the local daemon and reuse its service env.
    set -a
    # shellcheck disable=SC1090
    source "$SERVER_ENV"
    set +a
    default_url="$DEFAULT_LOCAL_URL"
  fi
  USAGEWIDGET_URL="${USAGEWIDGET_URL:-$default_url}"
  USAGEWIDGET_DEPLOY_HOST="${USAGEWIDGET_DEPLOY_HOST:-$DEFAULT_HOST}"
  USAGEWIDGET_REPO="${USAGEWIDGET_REPO:-$DEFAULT_REPO}"
  # strip trailing slash
  USAGEWIDGET_URL="${USAGEWIDGET_URL%/}"
}

require_token() {
  load_config
  local token="${USAGEWIDGET_TOKEN:-}"
  [[ ${#token} -ge 32 ]] || die "USAGEWIDGET_TOKEN must be at least 32 characters"
  [[ -n "${USAGEWIDGET_URL:-}" ]] || die "USAGEWIDGET_URL is not set"
}

require_host() {
  [[ -n "${USAGEWIDGET_DEPLOY_HOST:-}" ]] || die "USAGEWIDGET_DEPLOY_HOST is not set"
}

api() {
  require_token
  local method="$1" path="$2"
  shift 2
  # Optional: allow extra success codes via USAGEWIDGET_OK_CODES (space-separated)
  local ok_codes="${USAGEWIDGET_OK_CODES:-200 204}"
  local url="${USAGEWIDGET_URL}${path}"
  local tmp
  tmp="$(mktemp)"
  local code
  code="$(curl -sS -o "$tmp" -w "%{http_code}" -X "$method" \
    -H "Authorization: Bearer ${USAGEWIDGET_TOKEN}" \
    -H "Accept: application/json" \
    "$@" \
    "$url")" || { rm -f "$tmp"; die "request failed: $method $url"; }
  cat "$tmp"
  echo
  rm -f "$tmp"
  local c
  for c in $ok_codes; do
    [[ "$code" == "$c" ]] && return 0
  done
  die "HTTP $code for $method $path"
}

cmd_help() {
  cat <<'EOF'
usagewidget — talk to usagewidgetd or deploy it to your server

Config:  ~/.config/usagewidget/env  (mode 600, never commit)
         /etc/usagewidget/env on the server
  USAGEWIDGET_URL            required API base URL (local service auto-detected)
  USAGEWIDGET_TOKEN          bearer token (minimum 32 characters)
  USAGEWIDGET_DEPLOY_HOST    required SSH destination for remote commands
  USAGEWIDGET_REPO           local repo path

Commands:
  env [show]       Show config (token redacted)
  env sync         Pull token + write local config from the server
  env path         Print config file path
  health           GET /v1/health
  snapshot         GET /v1/snapshot
  settings         GET /v1/settings
  poll             POST /v1/poll  (force CodexBar sample)
  demo | test      POST /v1/demo/alert  (synthetic APNs + widget push)
  demo-provider    Show demo-provider status
  demo-provider on Enable it and poll immediately
  demo-provider off Disable it and poll immediately
  demo-provider poll  Poll with the current setting
  deploy           Cross-compile + install + restart on the server
  logs [-f]        journalctl -u usagewidget on the server
  status           systemd status on the server
  ssh [cmd...]     ssh to deploy host (default: interactive shell)
  help             This help

Examples:
  usagewidget env sync
  usagewidget health
  usagewidget poll
  usagewidget demo
  usagewidget deploy
  usagewidget logs -f
EOF
}

cmd_env_show() {
  load_config
  local active_config="$CONFIG_FILE"
  if [[ ! -f "$CONFIG_FILE" && -r "$SERVER_ENV" ]]; then
    active_config="$SERVER_ENV"
  fi
  echo "config:  $active_config"
  if [[ ! -f "$CONFIG_FILE" && ! -r "$SERVER_ENV" ]]; then
    echo "(missing — run: usagewidget env sync)"
    return
  fi
  echo "url:     ${USAGEWIDGET_URL}"
  echo "host:    ${USAGEWIDGET_DEPLOY_HOST}"
  echo "repo:    ${USAGEWIDGET_REPO}"
  if [[ -n "${USAGEWIDGET_TOKEN:-}" ]]; then
    local n="${#USAGEWIDGET_TOKEN}"
    echo "token:   (set; $n chars)"
  else
    echo "token:   (unset)"
  fi
  # optional APNS_* if present locally (for running usagewidgetd on Mac)
  if [[ -n "${APNS_KEY_ID:-}" || -n "${APNS_KEY_PATH:-}" ]]; then
    echo "apns:    key_id=${APNS_KEY_ID:-?} path=${APNS_KEY_PATH:-?} env=${APNS_ENV:-?} team=${APNS_TEAM_ID:-?}"
  fi
}

cmd_env_sync() {
  local host="${USAGEWIDGET_DEPLOY_HOST:-$DEFAULT_HOST}"
  # allow override from existing config
  if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    set -a; source "$CONFIG_FILE"; set +a
    host="${USAGEWIDGET_DEPLOY_HOST:-$host}"
  fi
  [[ -n "$host" ]] || die "USAGEWIDGET_DEPLOY_HOST is not set"
  [[ -n "${USAGEWIDGET_URL:-$DEFAULT_URL}" ]] || die "USAGEWIDGET_URL is not set"
  echo "Syncing token from ${host}…"
  local token
  token="$(ssh -o BatchMode=yes "$host" 'grep ^USAGEWIDGET_TOKEN= /etc/usagewidget/env | cut -d= -f2-')" \
    || die "ssh failed — is Tailscale up and deploy host reachable?"
  token="$(printf '%s' "$token" | tr -d '\r\n')"
  [[ ${#token} -ge 32 ]] || die "unexpected token from remote"

  mkdir -p "$CONFIG_DIR"
  umask 077
  {
    echo "# UsageWidget client config — do not commit"
    echo "# Managed by: usagewidget env sync"
    printf 'USAGEWIDGET_URL=%q\n' "${USAGEWIDGET_URL:-$DEFAULT_URL}"
    printf 'USAGEWIDGET_TOKEN=%q\n' "$token"
    printf 'USAGEWIDGET_DEPLOY_HOST=%q\n' "$host"
    printf 'USAGEWIDGET_REPO=%q\n' "${USAGEWIDGET_REPO:-$DEFAULT_REPO}"
  } >"$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE"
  echo "Wrote $CONFIG_FILE (mode 600)"
  cmd_env_show
}

cmd_deploy() {
  load_config
  require_host
  [[ -n "${USAGEWIDGET_REPO:-}" ]] || die "USAGEWIDGET_REPO is not set"
  local repo="${USAGEWIDGET_REPO}"
  local script="$repo/server/deploy/redeploy.sh"
  [[ -x "$script" || -f "$script" ]] || die "redeploy script missing: $script"
  USAGEWIDGET_DEPLOY_HOST="${USAGEWIDGET_DEPLOY_HOST}" "$script"
}

cmd_logs() {
  load_config
  require_host
  local extra=(-n 50 --no-pager)
  if [[ "${1:-}" == "-f" || "${1:-}" == "--follow" ]]; then
    extra=(-f)
  fi
  ssh -o BatchMode=yes "${USAGEWIDGET_DEPLOY_HOST}" "journalctl -u usagewidget ${extra[*]}"
}

cmd_status() {
  load_config
  require_host
  ssh -o BatchMode=yes "${USAGEWIDGET_DEPLOY_HOST}" "systemctl status usagewidget --no-pager | head -30"
}

cmd_demo_provider() {
  local action="${1:-status}"
  case "$action" in
    status) api GET /v1/settings ;;
    on)
      api PUT /v1/settings -H "Content-Type: application/json" -d '{"demoProviderEnabled":true}'
      USAGEWIDGET_OK_CODES="200 502" api POST /v1/poll
      ;;
    off)
      api PUT /v1/settings -H "Content-Type: application/json" -d '{"demoProviderEnabled":false}'
      USAGEWIDGET_OK_CODES="200 502" api POST /v1/poll
      ;;
    poll) USAGEWIDGET_OK_CODES="200 502" api POST /v1/poll ;;
    *) die "unknown demo-provider action: $action (status|on|off|poll)" ;;
  esac
}

cmd_ssh() {
  load_config
  require_host
  if [[ $# -eq 0 ]]; then
    ssh "${USAGEWIDGET_DEPLOY_HOST}"
  else
    ssh -o BatchMode=yes "${USAGEWIDGET_DEPLOY_HOST}" "$@"
  fi
}

main() {
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    help|-h|--help) cmd_help ;;
    env)
      case "${1:-show}" in
        show|"") cmd_env_show ;;
        sync) cmd_env_sync ;;
        path) echo "$CONFIG_FILE" ;;
        *) die "unknown env subcommand: $1 (show|sync|path)" ;;
      esac
      ;;
    health) api GET /v1/health ;;
    snapshot) api GET /v1/snapshot ;;
    settings) api GET /v1/settings ;;
    poll) USAGEWIDGET_OK_CODES="200 502" api POST /v1/poll ;;
    demo|test|demo-alert|alert) api POST /v1/demo/alert ;;
    demo-provider) cmd_demo_provider "$@" ;;
    deploy|redeploy) cmd_deploy "$@" ;;
    logs) cmd_logs "$@" ;;
    status) cmd_status ;;
    ssh) cmd_ssh "$@" ;;
    *) die "unknown command: $cmd (try: usagewidget help)" ;;
  esac
}

main "$@"
